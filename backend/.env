# Server Configuration
PORT=5000

# Database Configuration
# Using local PostgreSQL on port 5432 (unrestricted trust authentication)
DATABASE_URL="postgresql://postgres@localhost:5432/handyman?schema=public"
DIRECT_URL="postgresql://postgres@localhost:5432/handyman"

# Authentication Secrets
JWT_SECRET="super-secret-dummy-key"

# Stripe Configuration
STRIPE_SECRET_KEY="sk_test_dummy_stripe_secret_key"
STRIPE_WEBHOOK_SECRET="whsec_dummy_webhook_secret_key"

# Paystack Configuration
PAYSTACK_SECRET_KEY="sk_test_dummy_paystack_secret_key"

# Flutterwave Configuration
FLUTTERWAVE_SECRET_KEY="FLWSECK_TEST-dummy_flutterwave_secret_key"

# ── Email (SMTP / Nodemailer) ────────────────────────────────────────────────
# Leave SMTP_HOST blank to disable email notifications (safe for local dev)
# Gmail example: SMTP_HOST=smtp.gmail.com  SMTP_PORT=465  SMTP_SECURE=true
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM="Akpoaza <your-email@gmail.com>"

# ── SMS (Twilio) ─────────────────────────────────────────────────────────────
# Leave TWILIO_ACCOUNT_SID blank to disable SMS notifications (safe for local dev)
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_FROM_NUMBER=+1234567890
