# Server Configuration
PORT=5000

# Database Configuration (Prisma)
# Replace with your actual PostgreSQL connection strings (e.g. Supabase, local Postgres)
DATABASE_URL="postgresql://user:password@localhost:5432/handyman?schema=public"
DIRECT_URL="postgresql://user:password@localhost:5432/handyman"

# Authentication Secrets
# Secure random key used for JWT signing and verification
JWT_SECRET="replace_with_a_secure_long_random_string_in_production"

# Stripe Configuration
# Retrieve these from your Stripe Dashboard (Developers > API keys & Webhooks)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Paystack Configuration
# Retrieve this from your Paystack Dashboard (Settings > API Keys & Webhooks)
PAYSTACK_SECRET_KEY="sk_test_..."

# Flutterwave Configuration
# Retrieve this from your Flutterwave Dashboard (Settings > API Keys)
FLUTTERWAVE_SECRET_KEY="FLWSECK_TEST-..."
