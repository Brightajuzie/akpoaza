# ============================================================
# FixMart Backend — Environment Variables Reference
# Copy this file to .env and fill in all required values.
# Never commit your real .env file to source control.
# ============================================================

# ────────────────────────────────────────────────────────────
# Server
# ────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production   # Set to "development" locally, "production" on Render

# ────────────────────────────────────────────────────────────
# Database (Prisma / Supabase / PostgreSQL)
# DATABASE_URL  → PgBouncer pooled URL  (port 6543, ?pgbouncer=true)
# DIRECT_URL    → Direct connection URL (port 5432, for migrations)
# Both are required. Get them from: Supabase › Settings › Database
# ────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-eu-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-eu-west-2.pooler.supabase.com:5432/postgres"

# ────────────────────────────────────────────────────────────
# Authentication
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ────────────────────────────────────────────────────────────
JWT_SECRET="replace_with_a_secure_random_64_char_hex_string"

# ────────────────────────────────────────────────────────────
# Stripe  (Developers › API keys & Webhooks)
# ────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ────────────────────────────────────────────────────────────
# Paystack  (Settings › API Keys & Webhooks › paystack.com)
# ────────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY="sk_live_..."

# ────────────────────────────────────────────────────────────
# Flutterwave  (Settings › API Keys › dashboard.flutterwave.com)
# ────────────────────────────────────────────────────────────
FLUTTERWAVE_SECRET_KEY="FLWSECK-..."

# ────────────────────────────────────────────────────────────
# OPay  (Merchant Dashboard › Settings › API)
# ────────────────────────────────────────────────────────────
OPAY_MERCHANT_ID="your_opay_merchant_id"
OPAY_PUBLIC_KEY="your_opay_public_key"
OPAY_SECRET_KEY="your_opay_secret_key"

# ────────────────────────────────────────────────────────────
# Dojah KYC  (app.dojah.io › Settings)
# Leave blank to run in Sandbox/Mock mode automatically.
# ────────────────────────────────────────────────────────────
DOJAH_APP_ID="your_dojah_app_id"
DOJAH_SECRET_KEY="your_dojah_secret_key"
DOJAH_BASE_URL="https://api.dojah.io"
DOJAH_SANDBOX="false"   # Set "true" to force mock KYC responses regardless of API key presence

# ────────────────────────────────────────────────────────────
# Google OAuth  (console.cloud.google.com › APIs › Credentials)
# ────────────────────────────────────────────────────────────
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID="xxxx.apps.googleusercontent.com"
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID="xxxx.apps.googleusercontent.com"
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID="xxxx.apps.googleusercontent.com"

# ────────────────────────────────────────────────────────────
# Twilio SMS  (console.twilio.com)
# Leave blank to disable SMS notifications (in-app + email still work).
# ────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your_twilio_auth_token"
TWILIO_FROM_NUMBER="+1234567890"   # Twilio-provided phone number (E.164 format)

# ────────────────────────────────────────────────────────────
# SMTP Email  (any SMTP provider: Gmail, Brevo, Resend, etc.)
# Leave SMTP_HOST blank to disable email notifications.
# ────────────────────────────────────────────────────────────
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"   # "true" for port 465 (SSL), "false" for STARTTLS
SMTP_USER="your@email.com"
SMTP_PASS="your_smtp_password"
SMTP_FROM="FixMart <noreply@fixmart.app>"

# ────────────────────────────────────────────────────────────
# Internal webhook secret (escrow split endpoint)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ────────────────────────────────────────────────────────────
WEBHOOK_SPLIT_SECRET="replace_with_a_random_secret_token"

# ────────────────────────────────────────────────────────────
# Cloudinary  (Image Storage — required in production)
# Sign up free at: https://cloudinary.com/users/register_free
# Get these from: Cloudinary Dashboard › Settings › API Keys
# Leave blank to use local-disk storage (development only).
# ────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"
